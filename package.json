{
  "name": "@sanamyvn/ai-ts",
  "version": "0.0.0",
  "description": "Shared AI primitives — prompt registry, conversation engine, session lifecycle",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/SanamyVN/ai-ts.git"
  },
  "private": false,
  "type": "module",
  "scripts": {
    "dev": "tsc -p tsconfig.build.json --watch",
    "build": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json --resolve-full-paths",
    "prepublishOnly": "pnpm run build",
    "test": "vitest run --project unit --project integration",
    "test:unit": "vitest run --project unit",
    "test:integration": "vitest run --project integration",
    "test:watch": "vitest",
    "test:cov": "vitest run --project unit --coverage",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "lint": "eslint \"{src,tests,__tests__}/**/*.ts\"",
    "check-types": "tsc --noEmit",
    "prepare": "husky"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "exports": {},
  "dependencies": {
    "mustache": "^4.0.0"
  },
  "peerDependencies": {
    "@sanamyvn/foundation": "^1.12.0",
    "@mastra/core": "^1.0.0",
    "drizzle-orm": ">=0.45.1",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@mastra/core": "^1.0.0",
    "@sanamyvn/foundation": "^1.12.0",
    "@types/mustache": "^4.2.0",
    "drizzle-orm": "^0.45.1",
    "zod": "^4.0.0",
    "@commitlint/cli": "^20.4.4",
    "@commitlint/config-conventional": "^20.4.4",
    "@sanamyvn/eslint-config": "^2.1.0",
    "@sanamyvn/typescript-config": "^2.0.0",
    "@sanamyvn/vitest-config": "^2.0.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@swc/core": "^1.15.18",
    "@types/node": "^24.12.0",
    "@vitest/coverage-v8": "^4.1.0",
    "conventional-changelog-conventionalcommits": "^9.3.0",
    "eslint": "^10.0.3",
    "husky": "^9.1.7",
    "semantic-release": "^25.0.3",
    "tsc-alias": "^1.8.16",
    "typescript": "5.9.3",
    "unplugin-swc": "^1.5.9",
    "vitest": "^4.1.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@swc/core"
    ]
  }
}
